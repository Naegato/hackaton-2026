{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-checks": {
      "dependsOn": ["^type-checks"]
    },
    "@hackaton-2k26/docker#up": {
      "cache": false
    },
    "@hackaton-2k26/docker#dev": {
      "dependsOn": ["@hackaton-2k26/docker#up"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["@hackaton-2k26/docker#up"],
      "cache": false,
      "persistent": true
    },
    "dev:build": {
      "dependsOn": ["@hackaton-2k26/docker#up"],
      "cache": false,
      "persistent": true
    }
  }
}
