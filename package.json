{
  "name": "hackaton-2k26",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:content": "turbo run dev --filter=@hackaton-2k26/content",
    "dev:app": "turbo run dev --filter=@hackaton-2k26/application",
    "dev:build": "turbo run dev:build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-checks": "turbo run type-checks"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
