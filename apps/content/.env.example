# /!\ les variables DB doivent correspondre à packages/docker/.env
DATABASE_URL=mongodb://user:password@127.0.0.1:27017/hackaton?authSource=admin
PAYLOAD_SECRET=YOUR_SECRET_HERE

# SMTP (MailHog en dev — port 1025, UI sur http://localhost:8025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

# URL publique de l'app (web mobile) — utilisée dans le lien de réinitialisation de mot de passe
APP_PUBLIC_URL=http://localhost:8081
