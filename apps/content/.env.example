# /!\ les variables DB doivent correspondre à packages/docker/.env
DATABASE_URL=mongodb://user:password@127.0.0.1:27017/hackaton?authSource=admin
PAYLOAD_SECRET=YOUR_SECRET_HERE

# SMTP (MailHog en dev — port 1025, UI sur http://localhost:8025)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

# URL publique de l'app (web mobile) — utilisée dans le lien de réinitialisation de mot de passe
APP_PUBLIC_URL=http://localhost:8081

# Google OAuth — créer les credentials sur https://console.cloud.google.com/
# GOOGLE_REDIRECT_URI doit être enregistré dans la liste des "Authorized redirect URIs" de la console Google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Deep-link de l'app mobile vers lequel le backend redirige après OAuth
# Expo Go (dev)        : exp://localhost:8081/--/
# Dev build / prod     : application://
APP_OAUTH_REDIRECT_URI=exp://localhost:8081/--/

# Mistral Vision (solution souveraine française) — vérification que la photo d'abonnement
# contient bien un visage humain. Clé à créer sur https://console.mistral.ai/api-keys
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
